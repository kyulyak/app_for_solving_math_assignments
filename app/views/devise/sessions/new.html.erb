<div class="auth-wrapper">
  <div class="auth-card">
    <div class="auth-card__header">
      <h1>Вход в аккаунт</h1>
      <p>Введите свои данные, чтобы продолжить работу</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <div class="field">
        <%= f.label :email, "Электронная почта" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input" %>
      </div>

      <div class="field">
        <%= f.label :password, "Пароль" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "input" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="checkbox-field">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me, "Запомнить меня" %>
        </div>
      <% end %>

      <div class="actions">
        <%= f.submit "Войти", class: "auth-button" %>
      </div>
    <% end %>

    <div class="auth-links">
      <%= link_to "Создать аккаунт", new_registration_path(resource_name) %>
      <% if devise_mapping.recoverable? %>
        <%= link_to "Забыли пароль?", new_password_path(resource_name) %>
      <% end %>
    </div>
  </div>
</div>