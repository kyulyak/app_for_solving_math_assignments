<div class="auth-page">
  <div class="auth-card">
    <div class="auth-card__top">
      <h1 class="auth-title">Вход в аккаунт</h1>
      <p class="auth-subtitle">Введите свои данные, чтобы продолжить работу</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <div class="form-group">
        <%= f.label :email, "Электронная почта", class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Пароль", class: "form-label" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "form-input" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="form-check">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me, "Запомнить меня" %>
        </div>
      <% end %>

      <div>
        <%= f.submit "Войти", class: "auth-submit" %>
      </div>
    <% end %>

    <div class="auth-footer-links">
      <%= link_to "Создать аккаунт", new_registration_path(resource_name) %>
      <% if devise_mapping.recoverable? %>
        <%= link_to "Забыли пароль?", new_password_path(resource_name) %>
      <% end %>
    </div>
  </div>
</div>