<style>
.auth-page {
  min-height: calc(100vh - 150px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
}

.auth-card {
  width: 100%;
  max-width: 480px;
  background: white;
  border-radius: 28px;
  padding: 40px 36px;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
  border: 1px solid #eef2ff;
}

.auth-card__top {
  text-align: center;
  margin-bottom: 32px;
}

.auth-title {
  font-size: 34px;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 12px;
}

.auth-subtitle {
  font-size: 15px;
  color: #64748b;
  line-height: 1.5;
}

.auth-form {
  display: flex;
  flex-direction: column;
  gap: 22px;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.form-label {
  font-size: 15px;
  font-weight: 600;
  color: #334155;
}

.form-hint {
  font-size: 13px;
  color: #64748b;
}

.form-input {
  width: 100%;
  padding: 14px 16px;
  border-radius: 14px;
  border: 1px solid #cbd5e1;
  background: #f8fafc;
  font-size: 15px;
  line-height: 1.4;
  color: #0f172a;
  outline: none;
  transition: all 0.2s ease;
}

.form-input:focus {
  border-color: #2563eb;
  background: #ffffff;
  box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
}

.auth-submit {
  width: 100%;
  margin-top: 8px;
  padding: 14px 18px;
  border: none;
  border-radius: 14px;
  background: linear-gradient(135deg, #2563eb, #7c3aed);
  color: #ffffff;
  font-size: 16px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.3s ease;
}

.auth-submit:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
}

.auth-footer-links {
  margin-top: 28px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  text-align: center;
}

.auth-footer-links a {
  text-decoration: none;
  color: #2563eb;
  font-weight: 600;
  font-size: 15px;
  transition: color 0.2s;
}

.auth-footer-links a:hover {
  text-decoration: underline;
  color: #1d4ed8;
}

.form-errors {
  margin-bottom: 20px;
  padding: 16px 18px;
  background: #fef2f2;
  border: 1px solid #fecaca;
  border-radius: 16px;
}

.form-errors__title {
  margin-bottom: 8px;
  color: #991b1b;
  font-weight: 700;
  font-size: 14px;
}

.form-errors__list {
  margin: 0;
  padding-left: 20px;
  color: #7f1d1d;
  line-height: 1.6;
  font-size: 14px;
}

@media (max-width: 640px) {
  .auth-card {
    padding: 28px 20px;
    border-radius: 24px;
  }
  .auth-title {
    font-size: 28px;
  }
  .auth-subtitle {
    font-size: 14px;
  }
}
</style>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-card__top">
      <h1 class="auth-title">Регистрация</h1>
      <p class="auth-subtitle">Создайте аккаунт для работы с математической платформой</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="form-group">
        <%= f.label :email, "Электронная почта", class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Пароль", class: "form-label" %>
        <% if @minimum_password_length %>
          <div class="form-hint">Минимум символов: <%= @minimum_password_length %></div>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Подтверждение пароля", class: "form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input" %>
      </div>

      <div>
        <%= f.submit "Зарегистрироваться", class: "auth-submit" %>
      </div>
    <% end %>

    <div class="auth-footer-links">
      <%= link_to "Уже есть аккаунт? Войти", new_session_path(resource_name) %>
    </div>
  </div>
</div>