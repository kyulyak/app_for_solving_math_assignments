<h1 class="text-3xl font-bold mb-6"><%= @topic.title %></h1>

<% if @subtopics.present? %>
  <h2 class="text-xl mb-4">Подтемы</h2>
<% else %>
  <h2 class="text-xl mb-4">Задачи</h2>
<% end %>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <% if @subtopics.present? %>
    <% @subtopics.each do |subtopic| %>
      <div class="bg-white p-6 rounded-lg shadow hover:shadow-lg transition">
        <h3 class="text-lg font-semibold">
          <%= link_to subtopic.title, topic_subtopic_path(@topic, subtopic) %>
        </h3>
      </div>
    <% end %>
  <% else %>
    <% @problems.each do |problem| %>
      <div class="bg-white p-6 rounded-lg shadow hover:shadow-lg transition">
        <h3 class="text-lg font-semibold">
          <%= link_to problem.title, problem_path(problem) %>
        </h3>
      </div>
    <% end %>
  <% end %>
</div>