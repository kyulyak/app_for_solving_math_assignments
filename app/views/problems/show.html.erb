<h1 class="text-2xl font-bold mb-4">
  <%= @problem.title %>
</h1>

<p class="mb-4">
  <%= @problem.content %>
</p>

<%= form_with url: check_answer_problem_path(@problem), method: :post do %>
  <%= hidden_field_tag :problem_id, @problem.id %>

  <%= label_tag :submitted_answer, "Ваш ответ" %><br>
  <%= text_field_tag :submitted_answer, nil, class: "border p-2 mb-2" %><br>

  <%= submit_tag "Проверить", class: "bg-blue-500 text-white px-4 py-2 rounded" %>
<% end %>

<% if flash[:result] %>
  <p class="mt-4 font-bold"><%= flash[:result] %></p>
<% end %>

<!-- Показ решения -->
<details class="mt-4">
  <summary class="cursor-pointer text-blue-600">Показать решение</summary>
  <p class="mt-2"><%= @problem.solution %></p>
</details>