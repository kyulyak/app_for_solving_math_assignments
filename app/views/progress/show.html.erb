<style>
.progress-page {
  display: flex;
  flex-direction: column;
  gap: 28px;
  margin-top: 40px;
}

.progress-hero {
  background: none;
  border: none;
  box-shadow: none;
  padding: 0;
  text-align: center;
}

.progress-hero h1 {
  font-size: 40px;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 12px;
}

.progress-hero p {
  color: #64748b;
  font-size: 18px;
  text-align: center;
}

.progress-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18px;
}

.progress-card {
  background: white;
  border: 1px solid #e2e8f0;
  border-radius: 20px;
  padding: 24px;
  box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
}

.progress-card__label {
  display: block;
  color: #64748b;
  font-size: 14px;
  margin-bottom: 10px;
}

.progress-card strong {
  font-size: 34px;
  color: #1e293b;
}

.progress-card--accent {
  background: linear-gradient(135deg, #2563eb, #7c3aed);
}

.progress-card--accent .progress-card__label,
.progress-card--accent strong {
  color: white;
}

.history-box {
  background: white;
  border: 1px solid #e2e8f0;
  border-radius: 24px;
  padding: 24px;
  box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
}

.history-box summary {
  cursor: pointer;
  list-style: none;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 22px;
  font-weight: 700;
}

.history-box summary::-webkit-details-marker {
  display: none;
}

.history-box summary::after {
  content: "▼";
  color: #7c3aed;
  font-size: 16px;
}

.history-box[open] summary::after {
  content: "▲";
}

.history-list {
  margin-top: 22px;
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.history-item {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 20px;
  padding: 22px;
}

.history-item__top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20px;
  margin-bottom: 18px;
}

.history-item__title h3 {
  font-size: 20px;
  color: #0f172a;
  margin-bottom: 8px;
}

.history-item__title p {
  color: #64748b;
  margin: 0;
}

.history-content {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.history-row {
  background: white;
  border-radius: 14px;
  padding: 14px 16px;
  border: 1px solid #e2e8f0;
}

.history-row strong {
  display: block;
  margin-bottom: 8px;
  color: #0f172a;
  font-size: 15px;
}

.history-row p {
  margin: 0;
  color: #334155;
  line-height: 1.6;
  word-break: break-word;
}

.result-badge {
  padding: 8px 14px;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 700;
  white-space: nowrap;
}

.result-badge--success {
  background: #dcfce7;
  color: #166534;
}

.result-badge--error {
  background: #fee2e2;
  color: #991b1b;
}

@media (max-width: 900px) {
  .progress-stats {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 640px) {
  .progress-stats {
    grid-template-columns: 1fr;
  }

  .history-item__top {
    flex-direction: column;
    align-items: flex-start;
  }

  .progress-hero h1 {
    font-size: 30px;
  }

  .history-box summary {
    font-size: 18px;
  }
}
</style>

<section class="progress-page">
  <div class="progress-hero">
    <h1>Мой прогресс</h1>
    <p>Здесь можно посмотреть историю решений и результаты попыток</p>
  </div>

  <div class="progress-stats">
    <div class="progress-card">
      <span class="progress-card__label">Всего попыток</span>
      <strong><%= @total_attempts %></strong>
    </div>

    <div class="progress-card">
      <span class="progress-card__label">Правильных ответов</span>
      <strong><%= @correct_attempts %></strong>
    </div>

    <div class="progress-card">
      <span class="progress-card__label">Неправильных ответов</span>
      <strong><%= @wrong_attempts %></strong>
    </div>

    <div class="progress-card progress-card--accent">
      <span class="progress-card__label">Решено задач</span>
      <strong><%= @solved_problems_count %></strong>
    </div>
  </div>

  <details class="history-box" open>
    <summary>
      <span>История решений</span>
    </summary>

    <div class="history-list">
      <% @attempts.each do |attempt| %>
        <div class="history-item">
          <div class="history-item__top">
            <div class="history-item__title">
              <h3><%= attempt.problem.title %></h3>

              <p>
                <strong>Тема:</strong>
                <%= attempt.problem.topic.title %>
              </p>
            </div>

            <% if attempt.is_correct? %>
              <span class="result-badge result-badge--success">
                Верно
              </span>
            <% else %>
              <span class="result-badge result-badge--error">
                Неверно
              </span>
            <% end %>
          </div>

          <div class="history-content">

            <div class="history-row">
              <strong>Задача</strong>

              <p>
                <%= attempt.problem_content.presence || attempt.problem.content %>
              </p>
            </div>

            <div class="history-row">
              <strong>Ваш ответ</strong>

              <p>
                <%= attempt.user_answer.presence || "Решение было показано" %>
              </p>
            </div>

            <div class="history-row">
              <strong>Правильный ответ</strong>

              <p>
                <%= attempt.correct_answer.presence || attempt.problem.correct_answer %>
              </p>
            </div>

            <div class="history-row">
              <strong>Правильное решение</strong>

              <p>
                <%= attempt.solution.presence || attempt.problem.solution %>
              </p>
            </div>

            <div class="history-row">
              <strong>Дата решения</strong>

              <p>
                <%= attempt.created_at.strftime("%d.%m.%Y %H:%M") %>
              </p>
            </div>

          </div>
        </div>
      <% end %>
    </div>
  </details>
</section>