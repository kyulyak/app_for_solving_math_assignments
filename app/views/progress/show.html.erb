<style>
.progress-page {
  display: flex;
  flex-direction: column;
  gap: 28px;
  margin-top: 40px;
}

.progress-hero {
  background: none;
  border: none;
  box-shadow: none;
  padding: 0;
  text-align: center; 
}

.progress-hero h1 {
  font-size: 40px;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 12px;
}

.progress-hero p {
  color: #64748b;
  font-size: 18px;
  text-align: center;
}

.progress-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18px;
}

.progress-card {
  background: white;
  border: 1px solid #e2e8f0;
  border-radius: 20px;
  padding: 24px;
  box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
}

.progress-card__label {
  display: block;
  color: #64748b;
  font-size: 14px;
  margin-bottom: 10px;
}

.progress-card strong {
  font-size: 34px;
  color: #1e293b;
}

.progress-card--accent {
  background: linear-gradient(135deg, #2563eb, #7c3aed);
}

.progress-card--accent .progress-card__label,
.progress-card--accent strong {
  color: white;
}

.history-box {
  background: white;
  border: 1px solid #e2e8f0;
  border-radius: 24px;
  padding: 24px;
  box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
}

.history-box summary {
  cursor: pointer;
  list-style: none;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 22px;
  font-weight: 700;
}

.history-box summary::-webkit-details-marker {
  display: none;
}

.history-box summary::after {
  content: "▼";
  color: #7c3aed;
  font-size: 16px;
}

.history-box[open] summary::after {
  content: "▲";
}

.history-box__hint {
  margin-left: auto;
  margin-right: 16px;
  color: #64748b;
  font-size: 14px;
  font-weight: 500;
}

.history-list {
  margin-top: 22px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.history-item {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 18px;
  padding: 20px;
}

.history-item__top {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: center;
  margin-bottom: 12px;
}

.history-item h3 {
  font-size: 18px;
  color: #1e293b;
}

.history-item p {
  color: #475569;
  margin-top: 6px;
}

.result-badge {
  padding: 6px 12px;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 700;
}

.result-badge--success {
  background: #dcfce7;
  color: #166534;
}

.result-badge--error {
  background: #fee2e2;
  color: #991b1b;
}

@media (max-width: 900px) {
  .progress-stats {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 560px) {
  .progress-stats {
    grid-template-columns: 1fr;
  }

  .progress-hero {
    padding: 24px;
  }

  .progress-hero h1 {
    font-size: 28px;
  }

  .history-box summary {
    font-size: 18px;
  }

  .history-box__hint {
    display: none;
  }
}
</style>

<section class="progress-page">
  <div class="progress-hero">
    <h1>Мой прогресс</h1>
    <p>Здесь можно посмотреть уже решенные вами задания </p>
  </div>

  <div class="progress-stats">
    <div class="progress-card">
      <span class="progress-card__label">Всего попыток</span>
      <strong><%= @total_attempts %></strong>
    </div>

    <div class="progress-card">
      <span class="progress-card__label">Правильных ответов</span>
      <strong><%= @correct_attempts %></strong>
    </div>

    <div class="progress-card">
      <span class="progress-card__label">Неправильных ответов</span>
      <strong><%= @wrong_attempts %></strong>
    </div>

    <div class="progress-card progress-card--accent">
      <span class="progress-card__label">Решено задач</span>
      <strong><%= @solved_problems_count %></strong>
    </div>
  </div>

  <details class="history-box">
    <summary>
      <span>История решений</span>
      <span class="history-box__hint"></span>
    </summary>

    <div class="history-list">
      <% @attempts.each do |attempt| %>
        <div class="history-item">
          <div class="history-item__top">
            <h3><%= attempt.problem.title %></h3>

            <% if attempt.is_correct? %>
              <span class="result-badge result-badge--success">Верно</span>
            <% else %>
              <span class="result-badge result-badge--error">Неверно</span>
            <% end %>
          </div>

          <p><strong>Попытка №:</strong> <%= attempt.attempt_number %></p>
          <p><strong>Ответ:</strong> <%= attempt.user_answer %></p>
        </div>
      <% end %>
    </div>
  </details>
</section>