<h1 class="text-2xl font-bold mb-4"><%= @subtopic.title %></h1>

<% @problems.each do |problem| %>
  <div class="bg-white p-4 rounded shadow mb-4">
    
    <!-- Название задачи -->
    <h2 class="font-semibold text-lg mb-2">
      <%= problem.title %>
    </h2>

    <!-- Условие -->
    <p class="mb-3">
      <%= problem.content %>
    </p>

    <!-- Кнопка -->
    <%= link_to "Решить",
        topic_subtopic_problem_path(@topic, @subtopic, problem),
        class: "text-blue-500 underline" %>

  </div>
<% end %>